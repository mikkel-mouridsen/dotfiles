font=JetBrainsMono Nerd Font 11
width=360
height=200
margin=16
padding=12,16
border-size=1
border-radius=14
icons=1
max-icon-size=48
default-timeout=5000
ignore-timeout=0

background-color={{colors.surface_container.default.hex}}cc
