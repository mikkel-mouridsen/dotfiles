# ── Mako notification daemon (fallback — Quickshell handles notifications) ──

font=JetBrainsMono Nerd Font 11
width=360
height=200
margin=16
padding=12,16
border-size=1
border-radius=14
icons=1
max-icon-size=48
default-timeout=5000
ignore-timeout=0

# Catppuccin Mocha colors
background-color=#1e1e2ecc
text-color=#cdd6f4
border-color=#cba6f7

[urgency=low]
default-timeout=3000
border-color=#45475a

[urgency=high]
default-timeout=0
border-color=#f38ba8
