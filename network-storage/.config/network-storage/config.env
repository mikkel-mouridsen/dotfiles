# Network Storage Configuration
# Edit these values to match your setup

# SMB server hostname (Tailscale name or IP)
SMB_SERVER=gondor

# SMB share names
SMB_SHARE_DOCS=documents
SMB_SHARE_MEDIA=media

# Folders to sync from the documents share to ~/
# These exist as //server/documents/<folder> and sync to ~/<folder>
SYNC_FOLDERS="Documents Music Pictures Videos"

# Local mount base directory
MOUNT_BASE=/mnt/network-storage

# Sync interval in minutes (for systemd timer)
SYNC_INTERVAL=15
